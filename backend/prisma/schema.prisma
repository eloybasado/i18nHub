generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// enums

enum GlobalRole {
  ADMIN
  MEMBER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

enum I18nPattern {
  SINGLE_FILE
  FOLDER_PER_LOCALE
  SUFFIX
  PREFIX
}

enum IssueType {
  MISSING_KEY
  UNUSED_KEY
  INTERPOLATION_MISMATCH
}

enum Tier {
  FREE
  PRO
}

// models
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  refreshTokenHash String? @map("refresh_token_hash")
  name         String
  role         GlobalRole @default(MEMBER)
  tier         Tier       @default(FREE)
  createdAt    DateTime @default(now()) @map("created_at")

  ownedProjects        Project[]
  projectMemberships   ProjectMember[]
  fileVersions         TranslationFileVersion[]

  @@map("users")
}

model Project {
  id                  String      @id @default(uuid())
  name                String
  description         String?
  i18nPattern         I18nPattern @map("i18n_pattern")
  ownerId             String      @map("owner_id")
  referenceLanguageId String?     @map("reference_language_id")
  aiContext           String?     @map("ai_context")
  aiGlossary          Json?       @map("ai_glossary")
  createdAt           DateTime    @default(now()) @map("created_at")

  owner              User            @relation(fields: [ownerId], references: [id])
  referenceLanguage  Language?       @relation("ReferenceLanguage", fields: [referenceLanguageId], references: [id])
  members            ProjectMember[]
  languages          Language[]      @relation("ProjectLanguages")
  fileGroups         FileGroup[]
  analysisReports    AnalysisReport[]

  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String      @map("project_id")
  userId    String      @map("user_id")
  role      ProjectRole @default(VIEWER)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Language {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  code      String
  name      String

  project                 Project          @relation("ProjectLanguages", fields: [projectId], references: [id], onDelete: Cascade)
  referenceInProjects     Project[]        @relation("ReferenceLanguage")
  translationFiles        TranslationFile[]
  issuesAsLanguage        AnalysisIssue[]  @relation("IssueLanguage")
  issuesAsReference       AnalysisIssue[]  @relation("IssueReferenceLanguage")

  @@unique([projectId, code])
  @@map("languages")
}

model FileGroup {
  id        String @id @default(uuid())
  projectId String @map("project_id")
  name      String

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  translationFiles TranslationFile[]
  analysisReports  AnalysisReport[]

  @@unique([projectId, name])
  @@map("file_groups")
}

model TranslationFile {
  id          String   @id @default(uuid())
  languageId  String   @map("language_id")
  fileGroupId String   @map("file_group_id")
  filename    String
  content     Json
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  language  Language                 @relation(fields: [languageId], references: [id], onDelete: Cascade)
  fileGroup FileGroup                @relation(fields: [fileGroupId], references: [id], onDelete: Cascade)
  versions  TranslationFileVersion[]

  @@unique([languageId, fileGroupId])
  @@map("translation_files")
}

model TranslationFileVersion {
  id                String   @id @default(uuid())
  translationFileId String   @map("translation_file_id")
  content           Json
  versionNumber     Int      @map("version_number")
  createdById       String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  comment           String?

  translationFile TranslationFile @relation(fields: [translationFileId], references: [id], onDelete: Cascade)
  createdBy       User            @relation(fields: [createdById], references: [id])

  @@unique([translationFileId, versionNumber])
  @@map("translation_file_versions")
}

model AnalysisReport {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  fileGroupId String?  @map("file_group_id")
  createdAt   DateTime @default(now()) @map("created_at")

  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileGroup FileGroup?      @relation(fields: [fileGroupId], references: [id])
  issues    AnalysisIssue[]

  @@map("analysis_reports")
}

model AnalysisIssue {
  id                  String    @id @default(uuid())
  reportId            String    @map("report_id")
  type                IssueType
  key                 String
  languageId          String    @map("language_id")
  referenceLanguageId String    @map("reference_language_id")
  details             Json?

  report            AnalysisReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  language          Language       @relation("IssueLanguage", fields: [languageId], references: [id])
  referenceLanguage Language       @relation("IssueReferenceLanguage", fields: [referenceLanguageId], references: [id])

  @@map("analysis_issues")
}